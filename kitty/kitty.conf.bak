#Keybindings
kitty_mod ctrl+shift
# +invio crea altro terminale, +l cambia layout
map F1 new_window_with_cwd

#Font (kitten choose-fonts da terminale)
font_family      Inconsolata nerd font
bold_font        auto
italic_font      auto
bold_italic_font auto

font_size 13.0



#Padding e margini
window_padding_width 10
window_margin_width 5



#Trasparenza e blur e tema
background_opacity 0.90
background_blur 1

tab_bar_style powerline 
tab_powerline_style slanted

#Animazione cursore


cursor_trail 200
cursor_trail_decay 0.2 0.4
cursor_trail_start_threshold 4

# BEGIN_KITTY_THEME (kittem theme se vuoi altrik)
# Noctalia
include current-theme.conf
# END_KITTY_THEME
